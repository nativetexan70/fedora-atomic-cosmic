[Unit]
Description=Unpack Homebrew into /var/home/linuxbrew on first boot
Documentation=https://brew.sh
ConditionPathExists=!/var/home/linuxbrew/.linuxbrew/bin/brew
After=local-fs.target
Before=systemd-user-sessions.service

[Service]
Type=oneshot
ExecStart=/usr/libexec/brew-setup.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
